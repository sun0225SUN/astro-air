---
interface Props {
  date: Date | string
}

const { date } = Astro.props

const validDate = typeof date === "string" ? new Date(date) : date
---

<time datetime={validDate.toISOString()}>
  {
    validDate
      .toLocaleDateString("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      })
      .replace(",", "")
      .replace(/\//g, "-")
  }
</time>
